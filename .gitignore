# Ignore generated CTFd challenge folders and hint-wallet manifests
challenges/*/
challenges/*.json

# Ignore Python compilation caches
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore local ctfcli hidden configurations (contains sensitive API tokens!)
.ctf/
/deployment-manifest.json
/validation-manifest.json

# Scratch ground-truth state written by scripts/test_staggered_concurrency.py
# and scripts/test_staggered_smoke.py for scripts/test_export_reconciliation.py
# to read -- regenerated every run, not meant to be committed.
scripts/local-ctfd/.state/

# Ignore system-specific files
.DS_Store
Thumbs.db
